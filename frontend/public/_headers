# ── Security headers for all routes ──────────────────────────────────────────
/*
  # MITM protection — force HTTPS for 2 years, include subdomains
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload

  # Prevent MIME-type sniffing
  X-Content-Type-Options: nosniff

  # Prevent clickjacking — disallow embedding in iframes
  X-Frame-Options: DENY

  # Limit referrer info sent to third parties
  Referrer-Policy: strict-origin-when-cross-origin

  # Permissions policy — only request camera permission, nothing else
  Permissions-Policy: camera=(self), microphone=(), geolocation=(), payment=()

  # Content Security Policy
  # script-src:    self + TF.js CDN + MediaPipe CDN + Ko-fi widget
  # connect-src:   self only (no backend calls — everything runs locally)
  # img-src:       self + flagcdn.com (flag icons) + data URIs
  # style-src:     self + unsafe-inline (needed for Tailwind inline styles)
  # worker-src:    blob (needed by TF.js WebGL backend)
  # frame-src:     ko-fi.com (the donation iframe)
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://storage.ko-fi.com; connect-src 'self' https://cdn.jsdelivr.net; img-src 'self' https://flagcdn.com data: blob:; style-src 'self' 'unsafe-inline'; worker-src blob:; frame-src https://ko-fi.com; object-src 'none'; base-uri 'self'

# ── Static assets — add long cache TTL ───────────────────────────────────────
# MediaPipe WASM and tflite files are large and versioned — cache aggressively
/mediapipe/*
  Cache-Control: public, max-age=31536000, immutable

# TF.js model files — versioned by you, safe to cache forever
/models/*
  Cache-Control: public, max-age=31536000, immutable
